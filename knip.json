{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.tsx",
    "src/main.tsx",
    "src/layout.tsx",
    "src/pages/**/*.tsx"
  ],
  "project": ["src/**/*.ts", "src/**/*.tsx"],
  "ignore": [],
  "ignoreFiles": [
    "src/components/ui/**",
    "src/hooks/**",
    "src/sdk/**",
    "src/types/**",
    "src/lib/**"
  ]
}
