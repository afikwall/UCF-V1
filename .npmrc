registry=https://registry.npmjs.org/
node-options=--experimental-require-module
node-options=--max_old_space_size=4096
legacy-peer-deps=true
engine-strict=true
# Never run dependency lifecycle scripts (postinstall/install/preinstall) — enforced at config level so it
# applies to EVERY install here (incl. an agent's `pnpm add`), not just commands that remember the flag.
# pnpm 10 already blocks dependency build scripts by default (no onlyBuiltDependencies allowlist); this also
# covers npm-style lifecycle scripts. Untrusted app deps must never execute code at install time.
ignore-scripts=true
# Boilerplate node_modules is installed at image-build time and is then symlinked across
# concurrent compilations. Disable pnpm's pre-command sync (introduced in pnpm 10/11) so a
# version mismatch can never trigger a destructive purge of the shared tree at runtime.
verify-deps-before-run=false

link-workspace-packages=true
hoist-pattern[]=*vite*
hoist-pattern[]=@vitejs/*
hoist-pattern[]=*opentelemetry*
hoist-pattern[]=@opentelemetry/*
shamefully-hoist=true